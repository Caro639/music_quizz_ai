{# templates/game/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Accueil - Blind Test IA{% endblock %}

{% block body %}
    <div class="home-container">
        <h1 class="main-title text-neon">🎵 BLIND TEST IA</h1>

        {# Affichage des erreurs si le code du salon est faux #}
        {% for message in app.flashes('error') %}
            <div class="alert-error animate-pop">
                {{ message }}
            </div>
        {% endfor %}

        <div class="home-grid">
        {# créer une partie en tant qu'hôte #}
            <div class="glass-card create-box">
                <h2 class="text-neon-magenta">Créer une partie</h2>
                <p>Tu veux être le maître du jeu ? Crée un salon et affiche-le sur grand écran pour tes amis !</p>

                <form method="POST" action="{{ path('app_game_create') }}">
                    <div class="input-group">
                        <label for="host_nickname">Ton Pseudo d'Hôte</label>
                        <input type="text" id="host_nickname" name="nickname" placeholder="Ex: ChefDuGame" required autocomplete="off">
                    </div>
                    <button type="submit" class="btn-neon-magenta">
                        Créer un Salon 🎮
                    </button>
                </form>
            </div>

        {# rejoindre une session en tant que joueur #}
            <div class="glass-card join-box">
                <h2 class="text-neon-cyan">Rejoindre une partie</h2>
                <p class="text-gray-400 text-sm mb-4">
                    Entre le code ou clique sur un salon disponible en temps réel ci-dessous.
                </p>

                {# --- ZONE DES SALONS EN TEMPS RÉEL (Contenue dans le bloc Rejoindre) --- #}
                <div style="margin-bottom: 25px;"
                {{ react_component('LiveLobbiesList', {
                    'waitingGames': waitingGames,
                    'mercureUrl': mercureUrl,
                }) }}>
                Chargements des salons...
                </div>

                {# --- FORMULAIRE DE CONNEXION UNIQUE AVEC CODE DU SALON --- #}
                <form action="{{ path('app_game_join') }}" method="POST">
                    <div class="input-group">
                        <label for="token-input">Code du salon</label>
                        <input
                            type="text"
                            name="token"
                            id="token-input"
                            maxlength="6"
                            placeholder="Ex : A3F2B7"
                            class="uppercase tracking-widest text-center"
                            autocomplete="off"
                            required
                        />
                    </div>

                    <div class="input-group">
                        <label for="nickname">Ton Pseudo</label>
                        <input type="text" id="nickname" name="nickname" placeholder="Pseudo" required autocomplete="off">
                    </div>

                    <button type="submit" class="btn-neon-cyan" style="width: 100%; margin-top: 10px;">
                        Entrer dans le salon 🚀
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
